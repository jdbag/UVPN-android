<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0B1623" android:fillViewport="true">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp"
        android:paddingTop="52dp" android:paddingBottom="40dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
            android:gravity="center_vertical" android:layout_marginBottom="16dp">
            <ImageView android:layout_width="34dp" android:layout_height="34dp"
                android:src="@drawable/ic_shield" android:layout_marginEnd="10dp"/>
            <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:text="U VPN"
                android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
            <TextView android:id="@+id/tvProtection"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚠️  Unprotected" android:textSize="12sp"
                android:textColor="#F59E0B" android:textStyle="bold"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--         SESSION / ADS CARD                         -->
        <!-- ═══════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/adCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="18dp"
            app:cardBackgroundColor="#0F1E30" app:cardCornerRadius="16dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <!-- Session title + icons -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="FREE ACCESS" android:textSize="10sp"
                        android:textColor="#3B82F6" android:letterSpacing="0.1" android:textStyle="bold"/>
                    <!-- Ad watch indicators -->
                    <ImageView android:id="@+id/ivStar1"
                        android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:tint="#2A3A4A" android:layout_marginEnd="4dp"/>
                    <ImageView android:id="@+id/ivStar2"
                        android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@android:drawable/btn_star_big_off"
                        android:tint="#2A3A4A"/>
                </LinearLayout>

                <!-- Session label -->
                <TextView android:id="@+id/tvSession"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Watch an ad to connect"
                    android:textSize="14sp" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:layout_marginBottom="14dp"/>

                <!-- Ad plan info -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="14dp">

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:background="#162236" android:padding="10dp"
                        android:layout_marginEnd="6dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="1 Ad" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="= 2 Hours Free" android:textSize="11sp" android:textColor="#8BA4C0"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:background="#1A1235" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="2 Ads" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="#FFFFFF"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="= 12 Hours Free 🎉" android:textSize="11sp" android:textColor="#8BA4C0"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Watch Ad 1 Button -->
                <Button android:id="@+id/btnAd1"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="▶  Watch Ad — Get 2 Hours Free"
                    android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"
                    android:backgroundTint="#2563EB" android:layout_marginBottom="8dp"/>

                <!-- Watch Ad 2 Button (shown after first ad) -->
                <Button android:id="@+id/btnAd2"
                    android:layout_width="match_parent" android:layout_height="48dp"
                    android:text="▶  Watch 2nd Ad — Upgrade to 12 Hours"
                    android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"
                    android:backgroundTint="#7C3AED" android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Status dot + label -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:gravity="center_vertical" android:layout_marginBottom="4dp">
            <View android:id="@+id/dotStatus" android:layout_width="10dp" android:layout_height="10dp"
                android:background="@drawable/dot_grey" android:layout_marginEnd="10dp"/>
            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="Not Connected"
                android:textSize="18sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
        </LinearLayout>
        <TextView android:id="@+id/tvStatusSub" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="Your real IP is visible"
            android:textSize="13sp" android:textColor="#8BA4C0" android:layout_marginBottom="22dp"/>

        <!-- Connect Button -->
        <Button android:id="@+id/btnConnect"
            android:layout_width="176dp" android:layout_height="176dp"
            android:layout_gravity="center_horizontal"
            android:text="CONNECT" android:textSize="16sp"
            android:textStyle="bold" android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB" android:elevation="4dp"
            android:layout_marginBottom="22dp"/>

        <!-- IP Info Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#162236" app:cardCornerRadius="16dp" app:cardElevation="0dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <TextView android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:text="YOUR CURRENT IP"
                        android:textSize="10sp" android:textColor="#8BA4C0" android:letterSpacing="0.08"/>
                    <Button android:id="@+id/btnRefreshIp"
                        android:layout_width="34dp" android:layout_height="34dp"
                        android:text="⟳" android:textSize="18sp" android:textColor="#3B82F6"
                        android:backgroundTint="#1E2F45" android:padding="0dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="IP ADDRESS" android:textSize="9sp" android:textColor="#8BA4C0"/>
                        <TextView android:id="@+id/tvIp" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Loading..."
                            android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="COUNTRY" android:textSize="9sp" android:textColor="#8BA4C0"/>
                        <TextView android:id="@+id/tvCountry" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="CITY" android:textSize="9sp" android:textColor="#8BA4C0"/>
                        <TextView android:id="@+id/tvCity" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="--"
                            android:textSize="13sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    </LinearLayout>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#1E2F45" android:layout_marginVertical="10dp"/>
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ISP: " android:textSize="11sp" android:textColor="#8BA4C0"/>
                    <TextView android:id="@+id/tvIsp" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textSize="11sp" android:textColor="#FFFFFF"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Speed Row -->
        <LinearLayout android:id="@+id/layoutSpeed"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="12dp"
            android:visibility="gone">
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:layout_marginEnd="5dp"
                app:cardBackgroundColor="#162236" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↑ UPLOAD" android:textSize="9sp" android:textColor="#8BA4C0"/>
                    <TextView android:id="@+id/tvUp" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.0"
                        android:textSize="17sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MB/s" android:textSize="9sp" android:textColor="#8BA4C0"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:layout_marginHorizontal="2dp"
                app:cardBackgroundColor="#162236" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="↓ DOWNLOAD" android:textSize="9sp" android:textColor="#8BA4C0"/>
                    <TextView android:id="@+id/tvDn" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="0.0"
                        android:textSize="17sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="MB/s" android:textSize="9sp" android:textColor="#8BA4C0"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content" android:layout_marginStart="5dp"
                app:cardBackgroundColor="#162236" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PING" android:textSize="9sp" android:textColor="#8BA4C0"/>
                    <TextView android:id="@+id/tvPing" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="--"
                        android:textSize="17sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ms" android:textSize="9sp" android:textColor="#8BA4C0"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Region Selector -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="CLOUDFLARE WARP REGION" android:textSize="10sp"
            android:textColor="#8BA4C0" android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>

        <androidx.cardview.widget.CardView android:id="@+id/cardServer"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            app:cardBackgroundColor="#162236" app:cardCornerRadius="14dp" app:cardElevation="0dp"
            android:foreground="?attr/selectableItemBackground"
            android:clickable="true" android:focusable="true">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                <LinearLayout android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:id="@+id/tvSelServer"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🇺🇸  United States"
                        android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    <TextView android:id="@+id/tvSelDetail"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🆓 Free • No Ads"
                        android:textSize="12sp" android:textColor="#8BA4C0" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="›" android:textSize="26sp" android:textColor="#8BA4C0"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
