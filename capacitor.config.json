{
  "appId": "com.uvpn.app",
  "appName": "U VPN",
  "webDir": ".",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  },
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "backgroundColor": "#0d1b2a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}
